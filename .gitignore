# ------------------------------
# Dependencies
# ------------------------------
**/node_modules/

# Package manager / tooling caches
.npm/
.pnpm-store/
**/.cache/
**/.parcel-cache/
**/.eslintcache

# ------------------------------
# Build outputs
# ------------------------------
**/.next/
backend/.next/
backend/out/
frontend/build/
**/dist/
**/coverage/
**/.nyc_output/

# ------------------------------
# Environment files
# ------------------------------
**/.env
**/.env.*
!**/.env.example

# ------------------------------
# Logs
# ------------------------------
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# ------------------------------
# OS / Editor
# ------------------------------
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/

# ------------------------------
# TypeScript / framework files
# ------------------------------
**/*.tsbuildinfo

# ------------------------------
# Temporary files
# ------------------------------
**/tmp/
**/temp/
**/*.pid
**/*.seed
**/*.stackdump
